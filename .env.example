# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLIENT PORTAL (Multi-tenant - public clients)
VITE_MSAL_CLIENT_ID_CLIENT="[Client Portal App ID]"
VITE_MSAL_TENANT_ID_CLIENT="organizations"

# TEAM PORTAL (Single-tenant - SMGTEC internal team)
VITE_MSAL_CLIENT_ID_TEAM="[Team Portal App ID]"
VITE_MSAL_TENANT_ID_TEAM="SMGTEC.onmicrosoft.com"

# GOOGLE TAG MANAGER
VITE_GTM_ID="GTM-WL8FX47G"

# CLOUDFLARE TURNSTILE (PUBLIC)
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=""

# CLOUDFLARE TURNSTILE (PRIVATE SECRET - Server side)
CLOUDFLARE_TURNSTILE_SECRET_KEY=""

# HUBSPOT INTEGRATION
HUBSPOT_SERVICE_KEY=""

